# =====================================================================
# 環境変数テンプレート
# このファイルをコピーして .env を作成し、実際の値を設定すること
#   cp .env.example .env
# .env は .gitignore に追加済みのため Git にコミットしない
# =====================================================================

# ------------------------------------------------------------------
# フロントエンド（Vite）
# ------------------------------------------------------------------
# Docker 外で npm run dev する場合のみ設定（Docker 内では不要）
# VITE_API_PROXY=http://localhost:8000

# ------------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------------
POSTGRES_DB=wbs_db
POSTGRES_USER=wbs_user
POSTGRES_PASSWORD=changeme_strong_password

# ------------------------------------------------------------------
# Django
# ------------------------------------------------------------------
# 必ず強力なランダム文字列に変更すること
# 生成例: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=changeme_django_secret_key

# 本番ドメインを指定（カンマ区切り）
ALLOWED_HOSTS=example.com,www.example.com

# フロントエンドのオリジンを指定（CORS）
CORS_ALLOWED_ORIGINS=https://example.com,https://www.example.com

# ------------------------------------------------------------------
# Gunicorn（本番）
# ------------------------------------------------------------------
# ワーカー数の目安: (CPU コア数 × 2) + 1
GUNICORN_WORKERS=3
